# ─── API ───────────────────────────────────────────────────
# Base URL of the ExpenseFlow backend API (must include /api/v1).
# REQUIRED in production (Vercel). If unset, the build falls back to
# http://localhost:5000/api/v1 which will NOT work once deployed.
VITE_API_URL=https://your-backend.onrender.com/api/v1

# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/expenseflow
MONGODB_URI_TEST=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/expenseflow_test

# ─── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Cloudinary (File Uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@expenseflow.app
EMAIL_FROM_NAME=ExpenseFlow
APP_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ─── Cookie ───────────────────────────────────────────────
COOKIE_SECRET=your-cookie-secret-min-32-chars
COOKIE_SECURE=false

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=dev
LOG_FILE_PATH=logs/app.log

# ─── Upload ───────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ─── Encryption ──────────────────────────────────────────
ENCRYPTION_KEY=your-32-char-encryption-key-here